{
  "name": "alamdar/php-slim-project-service-api",
  "description": "Portfolio-safe PHP 8 Slim backend API for project workflow workflows.",
  "type": "project",
  "require": {
    "php": "^8.2",
    "php-di/php-di": "^7.0",
    "slim/slim": "^4.14",
    "slim/psr7": "^1.7",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=always",
    "serve": "php -S 0.0.0.0:8088 -t public"
  }
}
